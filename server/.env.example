PORT=3000
NODE_ENV=development

# Em produção, use obrigatoriamente um caminho absoluto em um disco montado.
# Exemplo no Render com disco persistente montado em /var/data:
# DATABASE_URL=/var/data/database.sqlite
# Para desenvolvimento local, um caminho relativo continua permitido.
DATABASE_URL=./database.sqlite

# Separe origens adicionais por vírgula. GitHub Pages e portas locais de
# desenvolvimento já são permitidos pelo servidor.
CORS_ORIGINS=
