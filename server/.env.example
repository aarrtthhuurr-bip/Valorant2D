PORT=3000
NODE_ENV=development

# Usuário promovido a administrador na inicialização. Deixe vazio se a flag
# is_admin já for gerenciada diretamente no PostgreSQL.
ADMIN_USERNAME=

# Sal aleatório usado para a rotação determinística das ofertas diárias.
DAILY_OFFER_SECRET=

# URI fornecida pelo Neon, Supabase ou outro PostgreSQL gerenciado.
# Não publique credenciais reais neste arquivo.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require

# Tamanho máximo opcional do pool de conexões.
PG_POOL_MAX=10

# Render usa um proxy reverso antes da aplicação. Mantenha 1 salvo se a
# topologia do serviço não tiver proxies adicionais.
TRUST_PROXY_HOPS=1

# Validação TLS do PostgreSQL. O padrão seguro é true. Se o provedor utilizar
# uma CA privada, prefira informar o certificado em PG_SSL_CA_BASE64.
PG_SSL_REJECT_UNAUTHORIZED=false
PG_SSL_CA_BASE64=

# Separe origens adicionais por vírgula. GitHub Pages e portas locais de
# desenvolvimento já são permitidos pelo servidor.
CORS_ORIGINS=

# Limites opcionais. Os valores padrão já são adequados para uma instância.
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_RECOVERY_QUESTION=10
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_AUTH_WRITE=30
